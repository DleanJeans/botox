{
  "expo": {
    "name": "The Grim Keeper",
    "slug": "grim-keeper",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "exp+grim-keeper",
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "updates": {
      "url": "https://u.expo.dev/89799b1d-f54f-490e-bcf5-cdf38764f4da"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "android": {
      "package": "com.dleanjeans.grimkeeper",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "exp+grim-keeper"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "plugins": [
      "expo-router",
      "expo-status-bar",
      "./plugins/withJVMMemory"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "89799b1d-f54f-490e-bcf5-cdf38764f4da"
      }
    },
    "owner": "dleanjeans"
  }
}
